rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 認証済みユーザーのみ読み書き可能（共通ルール）
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(resource) {
      return resource.data.createdBy == request.auth.uid;
    }

    match /jigyosho_notes/{noteId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthed() && isOwner(resource);
      allow delete: if isAuthed() && isOwner(resource);
    }

    match /visit_logs/{logId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthed() && isOwner(resource);
    }

    match /contacts/{contactId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /jigyosho_documents/{docId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthed();
    }

    match /jigyosho_status/{jigyoshoId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }
  }
}
